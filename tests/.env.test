# Test environment variables for the Always-On AI Assistant

# Prompt template for the LLM
# Use {question} as a placeholder for the user's question
# NOTE: This is a simple template. You can customize it later with more complex instructions.
# For XML-like tags in prompts, use [| and |] instead of < and > to avoid parsing issues.
ASSISTANT_PROMPT_TEMPLATE=You are a helpful, friendly AI assistant. Answer the user's question concisely and accurately.\n\nUser: {question}

# TTS Configuration
# Default TTS engine (pyttsx3 or gtts)
TTS_ENGINE=pyttsx3

# Default voice ID for pyttsx3 (leave empty for system default)
TTS_VOICE_ID=

# Default speech rate for pyttsx3 (words per minute)
TTS_RATE=150

# Default speech volume for pyttsx3 (0.0 to 1.0)
TTS_VOLUME=1.0

# Default language code for gTTS
TTS_LANGUAGE=en

# LLM Configuration
# Default LLM model type (ollama, openai, anthropic, lmstudio)
LLM_MODEL_TYPE=ollama

# Default LLM model name
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.1

# Default base URL for the LLM API
LLM_BASE_URL=http://localhost:11434
